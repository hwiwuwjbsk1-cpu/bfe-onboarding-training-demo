{
  "name": "chukouyi-onboarding-quest",
  "description": "出口易新人入职闯关训练系统，基于 React、Vite、TypeScript 和 Phaser 扩展底座。",
  "version": "0.1.0",
  "author": "BFE / Chukouyi onboarding demo",
  "license": "MIT",
  "keywords": [
    "onboarding",
    "training",
    "gamification",
    "chukouyi",
    "react",
    "vite",
    "typescript"
  ],
  "scripts": {
    "dev": "vite --config vite/config.dev.mjs",
    "build": "node scripts/build-static.mjs",
    "preview": "vite preview --config vite/config.prod.mjs --host 127.0.0.1",
    "dev-nolog": "vite --config vite/config.dev.mjs",
    "build-nolog": "node scripts/build-static.mjs"
  },
  "dependencies": {
    "lucide-react": "^1.22.0",
    "phaser": "4.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.22.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "terser": "^5.28.1",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.26.1",
    "vite": "^6.3.1"
  }
}
